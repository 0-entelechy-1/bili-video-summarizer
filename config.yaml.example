# B站视频分析器 配置文件
# 复制为 config.yaml 后修改

# LLM 配置
llm:
  provider: zhipu          # 可选: zhipu / deepseek / interactive
  zhipu:
    api_key: "ZHIPU_API_KEY"            # 也可通过 ZHIPU_API_KEY 环境变量设置
    model: glm-4.7-flash
    max_tokens: 65536          # GLM-4.7-Flash 单次输出上限（官方推荐 65536，最大 128K）
    thinking_enabled: true     # 启用 GLM-4.7 思考模式；false = 直接回答（更快但可能更浅）
  deepseek:
    api_key: "DEEPSEEK_API_KEY"            # 也可通过 DEEPSEEK_API_KEY 环境变量设置
    base_url: https://api.deepseek.com
    model: deepseek-v4-flash

# 转录配置
transcriber:
  prefer: auto             # 可选: auto / whisper / volcengine
  sub_langs: zh-CN,zh-Hans,zh-TW,ai-zh  # yt-dlp 字幕语言列表（逗号分隔），中文人工优先，AI 兜底
  cookies_file: null       # 可选：浏览器导出的 cookies.txt 绝对路径，优先级高于 QR 登录 cookies
  whisper:
    model: tiny          # tiny/base/small/medium/large
    model_path: ./models    # 本地模型目录，放置模型文件后优先从此目录加载
  volcengine:
    token: ""              # 也可通过 BYTEDANCE_VC_TOKEN 环境变量设置
    appid: ""              # 也可通过 BYTEDANCE_VC_APPID 环境变量设置

# 清理配置
cleanup:
  auto_delete_video: true  # 分析完成后自动删除视频文件
  auto_delete_audio: false  # 语音识别完成后自动删除音频文件

# 下载配置
download:
  quality: 480p           # 视频下载画质

# 截图配置
screenshot:
  count: 10                # 关键截图数量
  quality: 2               # JPEG 质量 (1-31, 越小越好)

# B站配置
bilibili:
  cookie: ""              # B站 Cookie (如 SESSDATA=xxx; bili_jct=yyy)，也可通过 BILIBILI_COOKIE 环境变量设置